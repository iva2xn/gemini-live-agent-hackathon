{
    "manifest_version": 3,
    "name": "Gemini Autopilot Bridge",
    "version": "1.0",
    "permissions": [
        "sidePanel",
        "offscreen",
        "activeTab",
        "tabs"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_title": "Open Autopilot"
    },
    "side_panel": {
        "default_path": "sidepanel.html"
    }
}